<?xml version="1.0" encoding="UTF-8"?>
<suppressions xmlns="https://jeremylong.github.io/DependencyCheck/dependency-suppression.1.3.xsd">
    <!--
    OWASP Dependency Check Suppression File
    
    Add suppression entries here for known false positives.
    Each suppression should include a note explaining why it's safe to suppress.
    
    Example:
    <suppress>
        <notes>This is a false positive. The CVE does not apply to our usage.</notes>
        <cve>CVE-2023-XXXXX</cve>
    </suppress>
    -->

    <!-- Spring Boot Test dependencies (not shipped to production) -->
    <suppress>
        <notes>Test-scoped dependency, not included in production WAR</notes>
        <gav regex="true">.*:spring-boot-starter-test:.*</gav>
        <cpe regex="true">.*</cpe>
    </suppress>

    <!-- H2 Database (only used in dev/test, not in production) -->
    <suppress>
        <notes>H2 is used only for local development and testing, not in production deployments</notes>
        <gav regex="true">com\.h2database:h2:.*</gav>
        <cpe regex="true">.*</cpe>
    </suppress>

</suppressions>
